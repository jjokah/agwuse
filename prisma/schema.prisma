generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  VISITOR
  MEMBER
  DEPT_LEAD
  FINANCE
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  WIDOWED
  DIVORCED
}

enum TransactionType {
  TITHE
  OFFERING
  DONATION
  PLEDGE_PAYMENT
  EXPENSE
}

enum OfferingCategory {
  GENERAL
  SPECIAL
  MISSION
  BUILDING_FUND
  WELFARE
  THANKSGIVING
  HARVEST
  FIRST_FRUIT
  OTHER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  POS
  MOBILE_MONEY
  ONLINE
}

enum PledgeStatus {
  ACTIVE
  FULFILLED
  CANCELLED
  OVERDUE
}

enum ContentType {
  BLOG
  ANNOUNCEMENT
  NEWS
}

enum EventType {
  SERVICE
  REVIVAL
  CONFERENCE
  OUTREACH
  HARVEST
  OTHER
}

enum SubmissionType {
  PRAYER_REQUEST
  TESTIMONY
}

enum SubmissionStatus {
  PENDING
  APPROVED
  ARCHIVED
}

enum DepartmentCategory {
  MINISTRY
  COMMITTEE
  CHOIR
  OUTREACH
}

// ============================================================
// AUTH MODELS (Auth.js Prisma Adapter)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Token {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  type      String   // EMAIL_VERIFICATION | PASSWORD_RESET
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
  @@map("tokens")
}

// ============================================================
// CORE MODELS
// ============================================================

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  emailVerified DateTime?
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  dateOfBirth   DateTime?
  gender        Gender?
  maritalStatus MaritalStatus?
  address       String?       @db.Text
  occupation    String?
  memberSince   DateTime?
  role          UserRole      @default(VISITOR)
  status        UserStatus    @default(PENDING)
  profilePhoto  String?
  image         String?
  name          String?

  departmentId String?
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])

  accounts             Account[]
  sessions             Session[]
  ledDepartments       Department[]           @relation("DepartmentLeader")
  transactions         FinancialTransaction[] @relation("TransactionMember")
  recordedTransactions FinancialTransaction[] @relation("TransactionRecordedBy")
  pledges              Pledge[]
  blogPosts            BlogPost[]
  events               Event[]
  submissions          Submission[]
  auditLogs            AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([departmentId])
  @@map("users")
}

model Department {
  id          String             @id @default(cuid())
  name        String             @unique
  description String?            @db.Text
  category    DepartmentCategory
  isActive    Boolean            @default(true)

  leaderId String?
  leader   User?   @relation("DepartmentLeader", fields: [leaderId], references: [id])

  members User[] @relation("DepartmentMembers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

// ============================================================
// FINANCIAL MODELS
// ============================================================

model FinancialTransaction {
  id              String           @id @default(cuid())
  type            TransactionType
  category        OfferingCategory @default(GENERAL)
  customCategory  String?
  amount          Decimal          @db.Decimal(12, 2)
  currency        String           @default("NGN")
  paymentMethod   PaymentMethod
  referenceNumber String?
  date            DateTime
  notes           String?          @db.Text
  receiptNumber   String?          @unique
  paystackRef     String?

  memberId     String?
  member       User?   @relation("TransactionMember", fields: [memberId], references: [id])
  recordedById String
  recordedBy   User    @relation("TransactionRecordedBy", fields: [recordedById], references: [id])

  pledgeId String?
  pledge   Pledge? @relation(fields: [pledgeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([date])
  @@index([memberId])
  @@index([category])
  @@index([recordedById])
  @@index([date, type])
  @@map("financial_transactions")
}

model Pledge {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  amount      Decimal      @db.Decimal(12, 2)
  amountPaid  Decimal      @default(0) @db.Decimal(12, 2)
  currency    String       @default("NGN")
  startDate   DateTime
  endDate     DateTime?
  status      PledgeStatus @default(ACTIVE)

  memberId String
  member   User   @relation(fields: [memberId], references: [id])

  payments FinancialTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([status])
  @@map("pledges")
}

model FinancialCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  type        String  // INCOME | EXPENSE
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())

  @@map("financial_categories")
}

// ============================================================
// CONTENT MODELS
// ============================================================

model BlogPost {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  content       String      @db.Text
  excerpt       String?     @db.Text
  type          ContentType @default(BLOG)
  featuredImage String?
  published     Boolean     @default(false)
  publishedAt   DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([type])
  @@index([published])
  @@index([publishedAt])
  @@map("blog_posts")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  startDate   DateTime
  endDate     DateTime?
  location    String    @default("AG Wuse, 53 Accra Street, Wuse Zone 5")
  type        EventType @default(SERVICE)
  imageUrl    String?
  isPublished Boolean   @default(false)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@index([type])
  @@map("events")
}

model Submission {
  id       String           @id @default(cuid())
  type     SubmissionType
  name     String?
  email    String?
  content  String           @db.Text
  isPublic Boolean          @default(false)
  status   SubmissionStatus @default(PENDING)

  submittedById String?
  submittedBy   User?  @relation(fields: [submittedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@map("submissions")
}

model GalleryImage {
  id           String  @id @default(cuid())
  url          String
  thumbnailUrl String?
  caption      String?
  albumName    String?
  sortOrder    Int     @default(0)

  createdAt DateTime @default(now())

  @@index([albumName])
  @@map("gallery_images")
}

model Sermon {
  id           String   @id @default(cuid())
  title        String
  speaker      String
  description  String?  @db.Text
  date         DateTime
  audioUrl     String?
  videoUrl     String?
  thumbnailUrl String?
  seriesName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("sermons")
}

// ============================================================
// SYSTEM MODELS
// ============================================================

model AuditLog {
  id        String  @id @default(cuid())
  action    String
  entity    String
  entityId  String
  details   String? @db.Text
  ipAddress String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ChurchSettings {
  key   String @id
  value String @db.Text

  updatedAt DateTime @updatedAt

  @@map("church_settings")
}
